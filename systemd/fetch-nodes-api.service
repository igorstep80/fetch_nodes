[Unit]
Description=Storj node API
After=network-online.target fetch-nodes-watch.service
Wants=network-online.target

[Service]
Type=simple
User=fetchnodes
WorkingDirectory=/opt/fetch_nodes
EnvironmentFile=/opt/fetch_nodes/.env
ExecStart=/usr/local/bin/fetch_nodes serve --db-path /opt/fetch_nodes/nodes.db --listen 127.0.0.1:8080
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
